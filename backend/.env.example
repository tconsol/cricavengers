NODE_ENV=development
PORT=5000

# MongoDB — use Atlas for production, local for dev
# Generate strong password: openssl rand -base64 24
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/cricavengers?appName=cricavengers

# JWT — MUST be cryptographically random in production
# Generate: openssl rand -base64 32
JWT_ACCESS_SECRET=replace_with_random_64_char_string
JWT_REFRESH_SECRET=replace_with_different_random_64_char_string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS — production should be your app's registered domain only
# Mobile apps omit Origin header so leaving blank allows native app traffic
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Firebase (for push notifications — add your service account values)
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
